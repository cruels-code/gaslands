            { name: "Bike", weight: "Lightweight", hull: 4, handling: 5, maxGear: 6, crew: 1, slots: 1, cost: 5, special: "Full Throttle (Long Straight always permitted), Pivot at Gear 1." },
            { name: "Bike with Sidecar", weight: "Lightweight", hull: 4, handling: 5, maxGear: 6, crew: 2, slots: 2, cost: 8, special: "Full Throttle (Long Straight always permitted), Pivot at Gear 1." },
            { name: "Ice Cream Truck", weight: "Middleweight", hull: 10, handling: 2, maxGear: 4, crew: 2, slots: 2, cost: 8, special: "Infuriating Jingle: Tailgaters get no collision hazards step 6." },
            { name: "Gyrocopter", weight: "Middleweight", hull: 4, handling: 4, maxGear: 6, crew: 1, slots: 0, cost: 10, special: "Airwolf (+2 hazard to 90-deg pivot), Airborne (ignore non-tall obstructions), Bombs Away (dropped weapons take 0 slots)." },
            { name: "Ambulance", weight: "Middleweight", hull: 12, handling: 2, maxGear: 5, crew: 3, slots: 3, cost: 20, special: "Uppers (collisions force +1 gear/hazard), Downers (smash removes 2 target hazards & reduces crew)." },
