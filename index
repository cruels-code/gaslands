        function changeUpgradeFacing(vehicleId, upgradeIndex, val) {
            const v = appState.vehicles.find(car => car.id === vehicleId);
            if (v && v.upgrades[upgradeIndex]) {
                v.upgrades[upgradeIndex].facing = val;
                renderVehicles();
                saveState();
            }
        }

        function selectPerk(p) {
            const v = appState.vehicles.find(car => car.id === activeModalTargetVehicleId);
            if (v) {
                if (v.perks.some(ex => ex.name === p.name)) {
                    alert("This vehicle already has the " + p.name + " perk.");
                    return;
                }
                v.perks.push({
                    name: p.name,
                    cost: p.cost,
                    class: p.class,
                    desc: p.desc
                });
                renderVehicles();
                saveState();
            }
        }

        function removeItem(vehicleId, itemType, index) {
            const v = appState.vehicles.find(car => car.id === vehicleId);
            if (v) {
                if (itemType === 'weapon') {
                    v.weapons.splice(index, 1);
                } else if (itemType === 'upgrade') {
                    v.upgrades.splice(index, 1);
                } else if (itemType === 'perk') {
                    v.perks.splice(index, 1);
                }
                renderVehicles();
                saveState();
            }
        }

        // In-game Play State Controllers
        function toggleHullDamage(id, index) {
            const v = appState.vehicles.find(car => car.id === id);
            if (v) {
                const baseInfo = VEHICLE_TYPES.find(t => t.name === v.type);
                let maxHull = baseInfo.hull;
                if (v.isPrisonCar && v.type === "Car") {
                    maxHull = baseInfo.hull - 2;
                }
                let armourCount = v.upgrades.filter(u => u.name === "Armour Plating").length;
                maxHull += (armourCount * 2);
                let microPlates = v.upgrades.filter(u => u.name === "MicroPlate Armour").length;
                maxHull += (microPlates * 2);
                
                // Left-to-right toggle logic:
                if (index <= v.damage) {
                    // Clicked an already damaged box: heal to just before this box
                    v.damage = index - 1;
                } else {
                    // Clicked a filled box: damage up to this box
                    v.damage = index;
                    const card = document.getElementById(`play-card-${v.id}`);
                    if (card) {
                        card.classList.add("shake-animation");
                        setTimeout(() => card.classList.remove("shake-animation"), 500);
                    }
                }

                if (v.damage >= maxHull) {
                    v.wrecked = true;
                    v.damage = maxHull;
                } else {
                    v.wrecked = false;
                }

                renderVehicles();
                saveState();
            }
        }

        // Hazards
        function setHazard(id, val) {
            const v = appState.vehicles.find(car => car.id === id);
            if (v) {
                v.hazard = val;
                
                let hazardLimit = 6;
                if (appState.sponsor === "Rusty's Bootleggers") {
                    hazardLimit = 8;
                }
                
                if (v.hazard >= hazardLimit) {
                    v.hazard = hazardLimit;
                }
                renderVehicles();
                saveState();
            }
        }

        function setGear(id, gearVal) {
            const v = appState.vehicles.find(car => car.id === id);
            if (v) {
                v.gear = gearVal;
                renderVehicles();
                saveState();
            }
        }

        function toggleStatus(id, prop) {
            const v = appState.vehicles.find(car => car.id === id);
            if (v) {
                v[prop] = !v[prop];
                renderVehicles();
                saveState();
            }
        }

        function toggleWeaponAmmo(vehicleId, ammoKey, bulletIndex, isChecked) {
            const v = appState.vehicles.find(car => car.id === vehicleId);
            if (v && v.ammoStates) {
                if (isChecked) {
                    v.ammoStates[ammoKey] = Math.max(v.ammoStates[ammoKey] || 0, bulletIndex);
                } else {
                    v.ammoStates[ammoKey] = Math.min(v.ammoStates[ammoKey] || 0, bulletIndex - 1);
                }
                saveState();
            }
        }

        // Global Play-Mode trackers (Turn & Phase)
        function adjustTurn(val) {
            appState.turn = Math.max(1, appState.turn + val);
            renderHeader();
            saveState();
        }

        function setPhase(phaseVal) {
            appState.phase = phaseVal;
            renderHeader();
            saveState();
        }

        // Votes
        function adjustVotes(val) {
            appState.votes = Math.max(0, appState.votes + val);
            renderHeader();
            saveState();
        }

        // Team Backup export / import files
        function exportTeam() {
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(appState, null, 2));
            const downloadAnchor = document.createElement('a');
            downloadAnchor.setAttribute("href",     dataStr);
            downloadAnchor.setAttribute("download", `${appState.sponsor.replace(/\s+/g, '_')}_gaslands_team.json`);
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click();
            downloadAnchor.remove();
        }

        function triggerImport() {
            const el = document.getElementById("import-file-input");
            if (el) el.click();
        }

        function importTeamFile(event) {
            const file = event.target.files[0];
            if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const parsed = JSON.parse(e.target.result);
                    if (parsed && Array.isArray(parsed.vehicles)) {
                        appState = { ...appState, ...parsed };
                        
                        // Fallbacks for turn/phase
                        if (appState.turn === undefined) appState.turn = 1;
                        if (appState.phase === undefined) appState.phase = 1;
                        
                        validateSponsorConstraints();
                        applySponsorTheme();
                        renderHeader();
                        renderSponsorInfo();
                        renderVehicles();
                        saveState();
                        alert("Sponsor Terminal: Team configuration import successful.");
                    } else {
                        alert("Diagnostics Error: invalid JSON file. Could not find vehicle roster.");
                    }
                } catch (err) {
                    alert("Diagnostics Parse Failure: " + err.message);
                }
            };
            reader.readAsText(file);
            event.target.value = ""; // Clear file selector state
        }

        function spendVote(action) {
            let cost = 1;
            if (action === 'reload' || action === 'executive') cost = 2;
            if (action === 'respawn') {
                cost = appState.sponsor === "Beverly" ? 1 : 3; 
            }

            if (appState.votes < cost) {
                alert("Not enough Audience Votes!");
                return;
            }

            adjustVotes(-cost);
            
            if (action === 'applause') {
                alert("Thunderous Applause spend: Select a vehicle you control and remove D6 Hazard Tokens from it!");
            } else if (action === 'rubber') {
                alert("Burn Rubber spend: Select a vehicle you control. It may immediately shift gear +/- 1 and gain a Hazard Token.");
            } else if (action === 'reload') {
                alert("Reload spend: Add 1 Ammo Token to a limited-ammo weapon or upgrade on one of your vehicles!");
            } else if (action === 'executive') {
                alert("Executive Intervention spend: Choose an enemy vehicle. It gains Hazard Tokens until it has 5 Hazards!");
            } else if (action === 'respawn') {
                alert("Respawn spend: Respawn a wrecked vehicle at half Hull Points. (If Beverly: Respawned vehicle gains Ghost Rider).");
            }
        }

        // Dedicated AI Prompt Tab Controller logic
        function goToPromptTab(vehicleId) {
            switchMode("prompt");
            const select = document.getElementById("prompt-vehicle-select");
            if (select) {
                select.value = vehicleId;
                updatePromptTabOutput();
            }
        }

        function populatePromptVehicleDropdown() {
            const select = document.getElementById("prompt-vehicle-select");
            if (!select) return;
            select.innerHTML = "";
            
            if (appState.vehicles.length === 0) {
                const opt = document.createElement("option");
                opt.value = "";
                opt.textContent = "No Vehicles Available";
                select.appendChild(opt);
                return;
            }

            appState.vehicles.forEach(v => {
                const opt = document.createElement("option");
                opt.value = v.id;
                opt.textContent = `${v.name} (${v.type})`;
                select.appendChild(opt);
            });
        }

        function updatePromptTabOutput() {
            const select = document.getElementById("prompt-vehicle-select");
            const output = document.getElementById("prompt-tab-output-text");
            
            if (!select || !output) return;
            const vehicleId = select.value;
            if (!vehicleId) {
                output.textContent = "Please build a vehicle in the Garage tab first.";
                return;
            }

            const v = appState.vehicles.find(car => car.id === vehicleId);
            if (!v) {
                output.textContent = "Vehicle not found.";
                return;
            }

            const baseInfo = VEHICLE_TYPES.find(t => t.name === v.type) || { weight: "Middleweight" };
            
            const typeDescriptions = {
                "Buggy": "lightweight off-road buggy with exposed roll cage frame and four medium-sized knobby off-road wheels",
                "Car": "midsize armored sedan car with four standard-sized wheels",
                "Performance Car": "low-profile aerodynamic high-speed performance sports car with four low-profile racing wheels",
                "Truck": "midsize rugged pickup truck with four large heavy-duty off-road wheels",
                "Heavy Truck": "heavy industrial transport truck with ten large commercial truck wheels",
                "Bus": "large heavy passenger transit bus with six large commercial wheels",
                "Drag Racer": "long-wheelbase drag racer with skinny small front tires and huge oversized rear drag slicks",
                "Bike": "lightweight off-road combat motorcycle with two medium spoked wheels",
                "Bike with Sidecar": "lightweight motorcycle with three medium spoked wheels including the sidecar wheel",
                "Ice Cream Truck": "boxy delivery ice cream truck with four medium commercial wheels",
                "Gyrocopter": "lightweight single-seat gyrocopter aircraft with three small landing gear wheels",
                "Ambulance": "heavy boxy medical ambulance van with four medium heavy-duty wheels",
                "Monster Truck": "massive monster truck suspension with four giant oversized rubber tractor wheels",
                "Helicopter": "military combat helicopter with dual landing skids and no wheels",
                "Tank": "tracked military combat tank with heavy metal tread tracks instead of wheels",
                "War Rig": "massive multi-wheeled articulated war rig semi-trailer truck with eighteen large commercial wheels"
            };
            const typeDesc = typeDescriptions[v.type] || `${baseInfo.weight.toLowerCase()} ${v.type.toLowerCase()}`;
            
            // Radio select for purpose
            const radios = document.getElementsByName("prompt-purpose");
            let purpose = "3d-model";
            for (let r of radios) {
                if (r.checked) purpose = r.value;
            }

            let description = "";
            let loadout = [];
            // Only include car-mounted weapons (exclude Crew Fired and RC Car Bombs)
            v.weapons.forEach(w => {
                if (w.category !== "Crew Fired" && w.name.toLowerCase() !== "rc car bombs") {
                    const facing = w.facing ? `${w.facing.toLowerCase()}-mounted ` : "";
                    loadout.push(`${facing}${w.name.toLowerCase()}`);
                }
            });
            v.upgrades.forEach(u => {
                if (u.name === "Ram" || u.name === "Exploding Ram") {
                    const facing = u.facing ? `${u.facing.toLowerCase()}-mounted ` : "front-mounted ";
                    loadout.push(`${facing}${u.name.toLowerCase()}`);
                } else {
                    loadout.push(u.name.toLowerCase());
                }
            });
            
            let loadoutText = "";
            if (loadout.length > 0) {
                loadoutText = `, customized with: ${loadout.join(', ')}`;
            } else {
                loadoutText = `, customized with rusty metal spikes and protective armor plating`;
            }

            if (purpose === "3d-model") {
                // 3D Model render
                description = `Isometric 3D model render of a post-apocalyptic Mad Max combat ${typeDesc}`;
                if (v.name) description += ` named '${v.name}'`;
                if (appState.sponsor && appState.sponsor !== "Sponsorless") {
                    description += `, sponsored by ${appState.sponsor} with custom decals`;
                }
                description += loadoutText;
                description += `. Isometric projection, 3/4 angled view, clear solid white background, studio product lighting, 3d game asset, no shadows, no background environment, perfect for 3D modeling software input, highly detailed clay render. No text, no letters, no labels, no watermarks on the image. Any rams must be fitted completely flush to the front and/or rear bumper of the vehicle body with zero gap, acting directly as the vehicle's bumper. Absolutely no extensions, no poles, no struts, no bars, no stilts, and no connection brackets extending the ram away from the body frame. The ram is welded directly to the bumper.`;
            } else {
                // In-Game full color render
                description = `Isometric 3D model render of a post-apocalyptic Mad Max combat ${typeDesc}`;
                if (v.name) description += ` named '${v.name}'`;
                if (appState.sponsor && appState.sponsor !== "Sponsorless") {
                    description += `, sponsored by ${appState.sponsor} with custom decals`;
                }
                description += loadoutText;
                description += `. Isometric projection, 3/4 angled view, full color concept art render, isolated on solid white background for transparency masking, studio product lighting, 3d game asset, no shadows, no background environment, perfect for game UI card art, highly detailed. No text, no letters, no labels, no watermarks on the image. Any rams must be fitted completely flush to the front and/or rear bumper of the vehicle body with zero gap, acting directly as the vehicle's bumper. Absolutely no extensions, no poles, no struts, no bars, no stilts, and no connection brackets extending the ram away from the body frame. The ram is welded directly to the bumper.`;
            }

            output.textContent = description;
        }

        function copyPromptTabText() {
            const output = document.getElementById("prompt-tab-output-text");
            if (!output) return;
            const text = output.textContent;
            if (text === "Please build a vehicle in the Garage tab first." || text === "Vehicle not found." || text === "No Vehicles Available") {
                return;
            }
            navigator.clipboard.writeText(text).then(() => {
                switchMode("garage");
            }).catch(err => {
                console.error("Copy failed: " + err);
                switchMode("garage");
            });
        }

        function toggleAccordion(header) {
            const content = header.nextElementSibling;
            const arrow = header.querySelector("span:last-child");
            content.classList.toggle("open");
            if (content.classList.contains("open")) {
                arrow.textContent = "▼";
            } else {
                arrow.textContent = "►";
            }
        }

        // Reset
        function confirmReset() {
            if (confirm("Are you sure you want to clear your current team? All customizations will be lost.")) {
                appState.vehicles = [];
                appState.votes = 0;
                addVehicle(false);
                renderVehicles();
                renderHeader();
                saveState();
            }
        }

        function confirmResetGame() {
            if (confirm("Reset current game stats (Damage, Hazards, Gears, Fire, Turn, Phase)? This keeps your vehicle builds intact.")) {
                appState.vehicles.forEach(v => {
                    v.damage = 0;
                    v.hazard = 0;
                    v.gear = 1;
                    v.onFire = false;
                    v.ghostRider = false;
                    v.distracted = false;
                    v.wrecked = false;
                    v.ammoStates = {};
                });
                appState.votes = 0;
                appState.turn = 1;
                appState.phase = 1;
                renderVehicles();
                renderHeader();
                saveState();
            }
        }

        // Zalgo Glitch Generator arrays & logic
        const ZALGO_UP = ['\u030d', '\u030e', '\u0304', '\u0305', '\u033f', '\u0311', '\u0306', '\u0310', '\u0352', '\u0357', '\u0351', '\u0307', '\u0308', '\u030a', '\u0309', '\u0349', '\u034a', '\u034b', '\u034c', '\u0359', '\u035a', '\u035b'];
        const ZALGO_DOWN = ['\u0316', '\u0317', '\u0318', '\u0319', '\u031c', '\u031d', '\u031e', '\u031f', '\u0320', '\u0324', '\u0325', '\u0326', '\u0329', '\u032a', '\u032b', '\u032c', '\u032d', '\u032e', '\u032f', '\u0330', '\u0331', '\u0332', '\u0333', '\u0339', '\u033a', '\u033b', '\u033c', '\u0345', '\u0347', '\u0348', '\u034d', '\u034e', '\u0353', '\u0354', '\u0355', '\u0356', '\u035c', '\u035d', '\u035e', '\u035f', '\u0360', '\u0362'];
        const ZALGO_MID = ['\u0315', '\u0334', '\u0335', '\u0336', '\u0337', '\u0338', '\u0358', '\u0361'];

        function toZalgo(text, intensity = 2) {
            let result = "";
            for (let i = 0; i < text.length; i++) {
                let char = text[i];
                if (char === " " || char === "\n") {
                    result += char;
                    continue;
                }
                result += char;
                // Distort 40% of characters
                if (Math.random() < 0.4) {
                    for (let j = 0; j < intensity; j++) {
                        const r = Math.random();
                        if (r < 0.33) {
                            result += ZALGO_UP[Math.floor(Math.random() * ZALGO_UP.length)];
                        } else if (r < 0.66) {
                            result += ZALGO_DOWN[Math.floor(Math.random() * ZALGO_DOWN.length)];
                        } else {
                            result += ZALGO_MID[Math.floor(Math.random() * ZALGO_MID.length)];
                        }
                    }
                }
            }
            return result;
        }

        // Periodic distracted text glitch animator
        setInterval(() => {
            if (appState.mode !== "play") return;
            
            appState.vehicles.forEach(vehicle => {
                if (!vehicle.distracted || vehicle.wrecked) return;
                
                const card = document.getElementById(`play-card-${vehicle.id}`);
                if (!card) return;
                
                // 1. Glitch Vehicle Name
                const nameEl = card.querySelector(".vehicle-name-block span:first-child");
                if (nameEl) {
                    if (!nameEl.dataset.original) {
                        nameEl.dataset.original = vehicle.name;
                    }
                    // Glitch name text randomly
                    nameEl.innerText = Math.random() < 0.75 ? toZalgo(nameEl.dataset.original, 2) : nameEl.dataset.original;
                }
                
                // 2. Glitch Weapons, Upgrades & Perks texts
                const items = card.querySelectorAll(".ref-item-header strong, .ref-item-desc");
                items.forEach(el => {
                    if (!el.dataset.original) {
                        el.dataset.original = el.innerText;
                    }
                    el.innerText = Math.random() < 0.5 ? toZalgo(el.dataset.original, 1) : el.dataset.original;
                });
            });
        }, 400);
    </script>
</body>
