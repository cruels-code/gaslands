<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gaslands Refuelled: Car Manager</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Orbitron:wght@400;600;800;900&family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* Colors - Camo & Desert Sand Theme */
            --bg-darker: #0d1109; /* Deep Olive Charcoal */
            --bg-dark: #1b2216; /* Olive Drab Green */
            --card-bg: rgba(43, 56, 36, 0.7); /* Weathered military olive */
            --card-border: rgba(212, 197, 169, 0.18); /* Desert sand border */
            
            --accent-orange: #d97706; /* Rusty industrial orange */
            --accent-orange-glow: rgba(217, 119, 6, 0.25);
            --accent-cyan: #84cc16; /* Lime hazard green */
            --accent-cyan-glow: rgba(132, 204, 22, 0.25);
            --danger-red: #ef4444;
            --danger-red-glow: rgba(239, 68, 68, 0.25);
            
            --text-primary: #f5eedc; /* Desert Tan sand */
            --text-muted: #a89f8c; /* Dusty tan */
            --text-dark: #5c5446; /* Muddy brown */
            
            /* Dynamic Accent default is Orange */
            --glow-color: var(--accent-orange);
            --glow-shadow: var(--accent-orange-glow);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-darker);
            background-image: 
                radial-gradient(at 0% 0%, rgba(27, 34, 22, 0.95) 0, transparent 65%),
                radial-gradient(at 50% 100%, var(--glow-shadow) 0, transparent 65%),
                radial-gradient(at 100% 0%, rgba(212, 197, 169, 0.08) 0, transparent 65%);
            background-attachment: fixed;
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
            padding-bottom: 3rem;
            transition: background 0.5s ease;
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 8px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-darker);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--text-dark);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--glow-color);
        }

        /* Typography & Layout */
        header {
            position: relative;
            background: linear-gradient(180deg, var(--bg-dark) 0%, rgba(27, 34, 22, 0.45) 100%);
            border-bottom: 2px solid var(--card-border);
            padding: 1.8rem 2rem 1.3rem 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            backdrop-filter: blur(12px);
        }

        .hazard-stripes {
            height: 4px;
            background: repeating-linear-gradient(
                -45deg,
                var(--accent-orange),
                var(--accent-orange) 10px,
                var(--bg-darker) 10px,
                var(--bg-darker) 20px
            );
            width: 100%;
            position: absolute;
            top: 0;
            left: 0;
            box-shadow: 0 1px 5px rgba(0,0,0,0.5);
        }

        .header-content {
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1.5rem;
        }

        .logo {
            display: flex;
            flex-direction: column;
        }

        .logo h1 {
            font-family: 'Special Elite', monospace;
            font-weight: 900;
            font-size: 1.8rem;
            letter-spacing: 2px;
            color: var(--text-primary);
            text-transform: uppercase;
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.1), 0 0 20px var(--glow-shadow);
            transition: all 0.3s ease;
        }

        .logo h1 span {
            color: var(--glow-color);
        }

        .logo .tagline {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: var(--text-muted);
            margin-top: 0.2rem;
        }

        /* Navigation & Mode Controls */
        .controls-panel {
            display: flex;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .global-stat {
            background: rgba(27, 34, 22, 0.8);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 0.5rem 1rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 100px;
        }

        .global-stat .label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        .global-stat .value {
            font-family: 'Orbitron', sans-serif;
            font-weight: 800;
            font-size: 1.1rem;
            color: var(--text-primary);
        }

        .global-stat.cans-tracker .value.over-budget {
            color: var(--danger-red);
            text-shadow: 0 0 8px var(--danger-red-glow);
            animation: pulse 1.5s infinite alternate;
        }

        /* Custom Inputs */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

        .input-group label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
        }

        select, input[type="number"], input[type="text"] {
            background: rgba(27, 34, 22, 0.8);
            border: 1px solid var(--card-border);
            color: var(--text-primary);
            padding: 0.5rem 0.8rem;
            border-radius: 6px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            outline: none;
            transition: all 0.3s ease;
        }

        select:focus, input[type="number"]:focus, input[type="text"]:focus {
            border-color: var(--glow-color);
            box-shadow: 0 0 8px var(--glow-shadow);
        }

        .btn {
            background: transparent;
            border: 1px solid var(--glow-color);
            color: var(--text-primary);
            padding: 0.6rem 1.2rem;
            border-radius: 6px;
            font-family: 'Orbitron', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            letter-spacing: 1px;
            cursor: pointer;
            text-transform: uppercase;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .btn:hover {
            background: var(--glow-color);
            color: var(--bg-darker);
            box-shadow: 0 0 15px var(--glow-shadow);
        }

        .btn-danger {
            border-color: var(--danger-red);
        }
        .btn-danger:hover {
            background: var(--danger-red);
            color: var(--text-primary);
            box-shadow: 0 0 15px var(--danger-red-glow);
        }

        .mode-toggle {
            display: flex;
            border: 1px solid var(--card-border);
            background: rgba(27, 34, 22, 0.8);
            border-radius: 8px;
            padding: 2px;
        }

        .mode-btn {
            padding: 0.5rem 1.2rem;
            border-radius: 6px;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 1px;
            border: none;
            background: transparent;
            color: var(--text-muted);
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .mode-btn.active {
            background: var(--glow-color);
            color: var(--bg-darker);
            box-shadow: 0 0 10px var(--glow-shadow);
        }

        /* Container & Grid layouts */
        main {
            max-width: 1400px;
            margin: 2rem auto;
            padding: 0 1.5rem;
        }

        .view-section {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .view-section.active {
            display: block;
        }

        .vehicles-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
            gap: 1.5rem;
            margin-top: 1.5rem;
        }

        @media (max-width: 600px) {
            .vehicles-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Play Dashboard Rework Styles */
        #play-vehicles-container {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .play-section-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--glow-color);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            padding-bottom: 0.3rem;
            margin-bottom: 0.6rem;
            text-shadow: 0 0 5px var(--glow-shadow);
        }

        .play-list-container {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        @media (min-width: 850px) {
            .play-dashboard-card {
                flex-direction: row !important;
                gap: 2rem;
                align-items: stretch;
            }
            .play-dashboard-left {
                flex: 1;
                display: flex;
                flex-direction: column;
                gap: 0.8rem;
                border-right: 1px solid var(--card-border);
                padding-right: 2rem;
            }
            .play-dashboard-right {
                flex: 1.2;
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }
        }

        /* Vehicle Card Base Styles */
        .vehicle-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 1.5rem;
            position: relative;
            backdrop-filter: blur(16px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            flex-direction: column;
            gap: 1.2rem;
        }

        .vehicle-card:hover {
            border-color: rgba(255, 255, 255, 0.15);
            box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            border-bottom: 1px solid var(--card-border);
            padding-bottom: 0.8rem;
        }

        .vehicle-name-block {
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
            flex-grow: 1;
        }

        .vehicle-title-input {
            background: transparent;
            border: 1px dashed transparent;
            font-family: 'Special Elite', monospace;
            font-size: 1.2rem;
            font-weight: 800;
            letter-spacing: 0.5px;
            color: var(--text-primary);
            padding: 0.2rem;
            border-radius: 4px;
            width: 100%;
            outline: none;
        }

        .vehicle-title-input:hover {
            border-color: var(--text-dark);
        }

        .vehicle-title-input:focus {
            border-color: var(--glow-color);
            background: rgba(0,0,0,0.2);
            box-shadow: none;
        }

        /* Card Stats Badge Grid */
        .stats-badge-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.5rem;
            background: rgba(0,0,0,0.15);
            padding: 0.6rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .stat-badge {
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .stat-badge .label {
            font-size: 0.6rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        .stat-badge .val {
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text-primary);
            margin-top: 0.1rem;
        }

        /* Garage Customizer Panels */
        .garage-section {
            border-top: 1px solid rgba(255,255,255,0.03);
            padding-top: 0.8rem;
        }

        .section-title {
            font-family: 'Special Elite', monospace;
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .item-list {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            margin-bottom: 0.6rem;
        }

        .equipped-item {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 6px;
            padding: 0.4rem 0.6rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.85rem;
            gap: 0.5rem;
        }

        .equipped-item-details {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            flex-grow: 1;
        }

        .equipped-item-name {
            font-weight: 600;
            color: var(--text-primary);
        }

        .equipped-item-desc {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .item-controls {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .remove-item-btn {
            background: transparent;
            border: none;
            color: var(--text-dark);
            cursor: pointer;
            font-size: 1.1rem;
            transition: color 0.2s;
            padding: 0.2rem;
        }

        .remove-item-btn:hover {
            color: var(--danger-red);
        }

        /* Play Mode Dashboard Elements */
        .play-dashboard-card {
            border-top: 4px solid var(--glow-color);
        }

        .play-dashboard-card.wrecked {
            border-top-color: var(--danger-red);
            opacity: 0.5;
        }

        .play-dashboard-card.wrecked::after {
            content: "WRECKED";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-15deg);
            border: 4px solid var(--danger-red);
            color: var(--danger-red);
            font-family: 'Orbitron', sans-serif;
            font-size: 2.5rem;
            font-weight: 900;
            padding: 0.5rem 2rem;
            background: rgba(9, 13, 22, 0.95);
            border-radius: 8px;
            box-shadow: 0 0 20px rgba(0,0,0,0.8);
            z-index: 10;
            letter-spacing: 4px;
            pointer-events: none;
        }

        /* Status Toggles Bar */
        .status-bar {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .status-chip {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--card-border);
            border-radius: 4px;
            padding: 0.3rem 0.6rem;
            font-size: 0.7rem;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            cursor: pointer;
            user-select: none;
            transition: all 0.3s;
            color: var(--text-muted);
        }

        .status-chip.on-fire.active {
            background: rgba(249, 115, 22, 0.15);
            border-color: #f97316;
            color: #f97316;
            box-shadow: 0 0 8px rgba(249, 115, 22, 0.4);
            animation: fire-pulse 1s infinite alternate;
        }

        .status-chip.ghost-rider.active {
            background: rgba(6, 182, 212, 0.15);
            border-color: var(--accent-cyan);
            color: var(--accent-cyan);
            box-shadow: 0 0 8px var(--accent-cyan-glow);
        }

        .status-chip.distracted.active {
            background: rgba(239, 68, 68, 0.15);
            border-color: var(--danger-red);
            color: var(--danger-red);
        }

        /* Dashboard Gearbox */
        .gearbox {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .gear-selector {
            display: grid;
            grid-template-columns: repeat(6, 1fr);
            gap: 0.3rem;
            background: rgba(0,0,0,0.2);
            padding: 0.3rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .gear-btn {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 6px;
            color: var(--text-muted);
            padding: 0.4rem 0;
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .gear-btn:hover:not(:disabled) {
            border-color: var(--glow-color);
            color: var(--text-primary);
        }

        .gear-btn.active {
            background: var(--glow-color);
            color: var(--bg-darker);
            border-color: var(--glow-color);
            box-shadow: 0 0 10px var(--glow-shadow);
        }

        .gear-btn:disabled {
            opacity: 0.1;
            cursor: not-allowed;
        }

        /* Hull damage track grid */
        .hull-tracker {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .hull-points-grid {
            display: grid;
            grid-template-columns: repeat(10, 1fr);
            gap: 0.25rem;
        }

        .hull-point-box {
            aspect-ratio: 1;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 4px;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .hull-point-box.filled {
            background: var(--accent-cyan);
            border-color: var(--accent-cyan);
            box-shadow: 0 0 5px var(--accent-cyan-glow);
        }

        .hull-point-box.damaged {
            background: transparent;
            border-color: rgba(239, 68, 68, 0.4);
        }

        .hull-point-box.damaged::after {
            content: "X";
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 0.75rem;
            font-weight: 900;
            color: var(--danger-red);
            text-shadow: 0 0 4px var(--danger-red-glow);
        }

        /* Hazard meter */
        .hazard-tracker {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .hazard-dots-row {
            display: flex;
            gap: 0.4rem;
            background: rgba(0,0,0,0.2);
            padding: 0.5rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.02);
            align-items: center;
            justify-content: space-between;
        }

        .hazard-dots {
            display: flex;
            gap: 0.35rem;
        }

        .hazard-dot {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            background: rgba(0,0,0,0.4);
            border: 1.5px solid rgba(255,255,255,0.1);
            cursor: pointer;
            transition: all 0.2s;
        }

        .hazard-dot.active {
            background: var(--glow-color);
            border-color: var(--glow-color);
            box-shadow: 0 0 8px var(--glow-shadow);
        }

        .hazard-dot.active.warning {
            background: var(--danger-red);
            border-color: var(--danger-red);
            box-shadow: 0 0 8px var(--danger-red-glow);
        }

        .wipeout-alert {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.7rem;
            font-weight: 800;
            color: var(--danger-red);
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid var(--danger-red);
            border-radius: 4px;
            padding: 0.1rem 0.4rem;
            text-align: center;
            animation: pulse 1s infinite alternate;
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        /* Game Turn & Phase Tracker */
        .turn-phase-tracker {
            background: rgba(27, 34, 22, 0.85);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
            flex-wrap: wrap;
            backdrop-filter: blur(12px);
        }
        
        .tracker-group {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .tracker-label {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 1px;
        }
        
        .turn-controls {
            display: flex;
            align-items: center;
            gap: 0.8rem;
            background: rgba(0,0,0,0.2);
            padding: 0.3rem 0.6rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.02);
        }
        
        .turn-btn {
            background: transparent;
            border: none;
            color: var(--glow-color);
            font-family: 'Orbitron', sans-serif;
            font-size: 1.1rem;
            font-weight: 800;
            cursor: pointer;
            padding: 0 0.4rem;
            transition: color 0.2s;
            outline: none;
        }
        
        .turn-btn:hover {
            color: var(--text-primary);
        }
        
        .turn-value {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.3rem;
            font-weight: 900;
            min-width: 24px;
            text-align: center;
        }
        
        .phase-selector {
            display: flex;
            gap: 0.35rem;
            background: rgba(0,0,0,0.2);
            padding: 0.3rem;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.02);
        }
        
        .phase-btn {
            background: rgba(27, 34, 22, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.05);
            color: var(--text-muted);
            font-family: 'Orbitron', sans-serif;
            font-weight: 700;
            font-size: 0.85rem;
            width: 32px;
            height: 32px;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .phase-btn:hover {
            border-color: var(--glow-color);
            color: var(--text-primary);
        }
        
        .phase-btn.active {
            background: var(--glow-color);
            color: var(--bg-darker);
            border-color: var(--glow-color);
            box-shadow: 0 0 10px var(--glow-shadow);
        }
        
        .phase-info {
            font-size: 0.85rem;
            color: var(--text-muted);
            font-weight: 500;
            flex-grow: 1;
            text-align: right;
        }
        
        @media (max-width: 768px) {
            .phase-info {
                text-align: left;
                width: 100%;
            }
        }

        /* Play Mode Ref Accordion */
        .accordion-header {
            background: rgba(0,0,0,0.15);
            padding: 0.4rem 0.6rem;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.8rem;
            font-family: 'Orbitron', sans-serif;
            text-transform: uppercase;
            border: 1px solid rgba(255,255,255,0.02);
            user-select: none;
        }

        .accordion-content {
            display: none;
            padding: 0.5rem 0.2rem 0 0.2rem;
            flex-direction: column;
            gap: 0.5rem;
        }

        .accordion-content.open {
            display: flex;
        }

        .ref-item {
            font-size: 0.8rem;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            padding-bottom: 0.3rem;
        }

        .ref-item:last-child {
            border-bottom: none;
        }

        .ref-item-header {
            font-weight: 600;
            display: flex;
            justify-content: space-between;
        }

        .ref-item-desc {
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-top: 0.1rem;
        }

        /* In-Game Ammo boxes */
        .ammo-spent-tracker {
            display: flex;
            gap: 0.2rem;
        }

        .ammo-checkbox {
            appearance: none;
            width: 14px;
            height: 14px;
            border: 1.5px solid var(--text-dark);
            border-radius: 3px;
            background: transparent;
            cursor: pointer;
            position: relative;
            outline: none;
        }

        .ammo-checkbox:checked {
            border-color: var(--glow-color);
            background: rgba(255, 255, 255, 0.1);
        }

        .ammo-checkbox:checked::after {
            content: "";
            position: absolute;
            top: 2px;
            left: 2px;
            width: 8px;
            height: 8px;
            background: var(--glow-color);
            border-radius: 1px;
            box-shadow: 0 0 4px var(--glow-shadow);
        }

        /* Warning text block */
        .warning-msg {
            color: var(--danger-red);
            font-size: 0.75rem;
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 6px;
            padding: 0.5rem;
            margin-top: 0.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .warning-msg-item {
            display: flex;
            align-items: flex-start;
            gap: 0.3rem;
        }

        .warning-msg-item::before {
            content: "⚠️";
            font-size: 0.8rem;
        }

        /* Team Selection / Garage Controls */
        .garage-top-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .garage-top-controls .left {
            display: flex;
            gap: 1rem;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        /* Audience Votes Controller HUD */
        .votes-hub {
            background: rgba(27, 34, 22, 0.85);
            border: 1px solid var(--card-border);
            border-radius: 12px;
            padding: 1rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
            backdrop-filter: blur(12px);
        }

        .votes-hud-left {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .votes-counter-big {
            display: flex;
            flex-direction: column;
            align-items: center;
            border-right: 1px solid var(--card-border);
            padding-right: 1.5rem;
        }

        .votes-counter-big .val {
            font-family: 'Orbitron', sans-serif;
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--glow-color);
            text-shadow: 0 0 10px var(--glow-shadow);
        }

        .votes-actions-grid {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .vote-action-btn {
            background: rgba(30, 41, 59, 0.5);
            border: 1px solid rgba(255,255,255,0.05);
            color: var(--text-primary);
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            font-size: 0.75rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-width: 110px;
            font-family: 'Orbitron', sans-serif;
        }

        .vote-action-btn:hover:not(:disabled) {
            border-color: var(--glow-color);
            background: rgba(255, 255, 255, 0.02);
            box-shadow: 0 0 8px var(--glow-shadow);
        }

        .vote-action-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .vote-action-btn .cost {
            font-size: 0.65rem;
            color: var(--glow-color);
            font-weight: bold;
            margin-top: 0.15rem;
        }

        .empty-team-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(30, 41, 59, 0.3);
            border: 1px dashed var(--card-border);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1rem;
            color: var(--text-muted);
        }

        /* Animations */
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(1.03); opacity: 0.8; }
        }

        @keyframes fire-pulse {
            0% { box-shadow: 0 0 4px rgba(249, 115, 22, 0.4); }
            100% { box-shadow: 0 0 12px #f97316; }
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            10%, 30%, 50%, 70%, 90% { transform: translateX(-4px); }
            20%, 40%, 60%, 80% { transform: translateX(4px); }
        }

        .shake-animation {
            animation: shake 0.5s ease-in-out;
        }

        /* State Effects Animations */
        @keyframes fire-flicker {
            0%, 100% {
                border-color: #f97316 !important;
                box-shadow: 
                    0 0 15px rgba(249, 115, 22, 0.4), 
                    inset 0 0 10px rgba(249, 115, 22, 0.3),
                    0 -5px 15px rgba(239, 68, 68, 0.4),
                    0 -12px 20px rgba(245, 158, 11, 0.2);
            }
            33% {
                border-color: #ef4444 !important;
                box-shadow: 
                    0 0 20px rgba(239, 68, 68, 0.5), 
                    inset 0 0 12px rgba(239, 68, 68, 0.4),
                    0 -8px 25px rgba(249, 115, 22, 0.6),
                    0 -15px 30px rgba(245, 158, 11, 0.3);
            }
            66% {
                border-color: #f59e0b !important;
                box-shadow: 
                    0 0 12px rgba(245, 158, 11, 0.4), 
                    inset 0 0 8px rgba(245, 158, 11, 0.3),
                    0 -4px 10px rgba(239, 68, 68, 0.3),
                    0 -10px 15px rgba(249, 115, 22, 0.2);
            }
        }

        @keyframes flame-pulse {
            0% { opacity: 0.25; }
            100% { opacity: 0.65; }
        }

        .play-dashboard-card.on-fire-card {
            animation: fire-flicker 0.35s infinite alternate !important;
            position: relative;
        }

        .play-dashboard-card.on-fire-card::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(0deg, rgba(239, 68, 68, 0.08) 0%, rgba(249, 115, 22, 0.04) 50%, transparent 100%);
            pointer-events: none;
            border-radius: 6px;
            animation: flame-pulse 0.6s infinite alternate;
            z-index: 1;
        }

        .play-dashboard-card.distracted-card {
            border-color: var(--danger-red) !important;
            box-shadow: 0 0 10px var(--danger-red-glow);
        }

        @keyframes ghost-fade {
            0% { opacity: 0.1; }
            100% { opacity: 1.0; }
        }

        .play-dashboard-card.ghost-card {
            animation: ghost-fade 3s ease-in-out infinite alternate !important;
        }
        .play-dashboard-card.ghost-card:hover {
            animation-play-state: paused !important;
            opacity: 0.85 !important;
        }

        .gear-phase-warning {
            background: rgba(239, 68, 68, 0.15);
            border: 1px dashed var(--danger-red);
            color: var(--danger-red);
            border-radius: 6px;
            padding: 0.4rem 0.8rem;
            font-size: 0.72rem;
            font-family: 'Special Elite', monospace;
            font-weight: bold;
            text-align: center;
            letter-spacing: 0.5px;
            animation: pulse 1s infinite alternate;
            margin-bottom: 0.5rem;
        }

        /* Modal Overlay for selections */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(9, 13, 22, 0.8);
            backdrop-filter: blur(8px);
            z-index: 1000;
            display: none;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.2s ease;
        }

        .modal-overlay.active {
            display: flex;
        }

        .modal-content {
            background: var(--bg-dark);
            border: 1px solid var(--glow-color);
            box-shadow: 0 0 25px var(--glow-shadow);
            border-radius: 12px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            overflow-y: auto;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--card-border);
            padding-bottom: 0.6rem;
        }

        .modal-header h3 {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.1rem;
            color: var(--glow-color);
            text-transform: uppercase;
        }

        .close-modal-btn {
            background: transparent;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 1.3rem;
        }

        .close-modal-btn:hover {
            color: var(--text-primary);
        }

        .modal-search {
            width: 100%;
            margin-bottom: 0.5rem;
        }

        .selection-list {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .selection-item {
            background: rgba(0,0,0,0.2);
            border: 1px solid rgba(255,255,255,0.03);
            border-radius: 6px;
            padding: 0.6rem 0.8rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
        }

        .selection-item:hover {
            background: rgba(255,255,255,0.05);
            border-color: var(--glow-color);
        }

        .selection-item-details {
            display: flex;
            flex-direction: column;
            gap: 0.15rem;
            flex-grow: 1;
        }

        .selection-item-title {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-primary);
        }

        .selection-item-meta {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        .selection-item-cost {
            font-family: 'Orbitron', sans-serif;
            font-weight: bold;
            font-size: 0.9rem;
            color: var(--glow-color);
            white-space: nowrap;
        }

        .selection-item-cost.slots {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* Quick rules helper float */
        .sponsor-info-banner {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            padding: 0.8rem 1rem;
            margin-bottom: 1.5rem;
            font-size: 0.85rem;
            line-height: 1.4;
            box-shadow: inset 0 0 5px rgba(0,0,0,0.5);
        }
        
        .sponsor-info-banner h4 {
            font-family: 'Orbitron', sans-serif;
            font-size: 0.9rem;
            color: var(--glow-color);
            text-transform: uppercase;
            margin-bottom: 0.3rem;
            letter-spacing: 0.5px;
        }

        .sponsor-info-banner p {
            color: var(--text-muted);
        }
    </style>
</head>
<body>

    <header>
        <div class="hazard-stripes"></div>
        <div class="header-content">
            <div class="logo">
                <h1 id="header-logo">Gaslands <span>Refuelled</span></h1>
                <div class="tagline">Tabletop Dashboard & Vehicle Builder</div>
            </div>
            
            <div class="controls-panel">
                <div class="input-group" id="sponsor-input-group">
                    <label for="sponsor-select">Team Sponsor</label>
                    <select id="sponsor-select" onchange="changeSponsor()">
                        <!-- Dynamic options loaded by JS -->
                    </select>
                </div>

                <div class="input-group" id="budget-input-group">
                    <label for="budget-input">Can Budget</label>
                    <input type="number" id="budget-input" value="50" min="1" max="1000" onchange="changeBudget()" style="width: 80px;">
                </div>

                <div class="global-stat cans-tracker">
                    <span class="label">Total Spent</span>
                    <span class="value" id="cans-spent-display">0 / 50</span>
                </div>

                <div class="mode-toggle">
                    <button class="mode-btn active" id="garage-mode-btn" onclick="switchMode('garage')">Garage</button>
                    <button class="mode-btn" id="play-mode-btn" onclick="switchMode('play')">Play Mode</button>
                    <button class="mode-btn" id="prompt-mode-btn" onclick="switchMode('prompt')">AI Prompt</button>
                </div>
            </div>
        </div>
    </header>

    <main>
        <!-- Sponsor Info Panel -->
        <div id="sponsor-info-panel" class="sponsor-info-banner" style="display: none;">
            <!-- Dynamic Sponsor Rules details -->
        </div>

        <!-- GARAGE VIEW -->
        <div id="garage-view" class="view-section active">
            <div class="garage-top-controls">
                <div class="left">
                    <button class="btn" onclick="addVehicle()">➕ Add Vehicle</button>
                    <button class="btn btn-danger" onclick="confirmReset()">🧹 Clear Team</button>
                </div>
                <div class="right" style="display: flex; gap: 0.5rem; align-items: center;">
                    <button class="btn" onclick="exportTeam()">📤 Export Team</button>
                    <button class="btn" onclick="triggerImport()">📥 Import Team</button>
                    <input type="file" id="import-file-input" style="display: none;" onchange="importTeamFile(event)">
                </div>
            </div>

            <div class="vehicles-grid" id="garage-vehicles-container">
                <!-- Vehicle customizers load here -->
            </div>
        </div>

        <!-- PLAY VIEW -->
        <div id="play-view" class="view-section">
            
            <!-- Game Turn & Phase Tracker -->
            <div class="turn-phase-tracker">
                <div class="tracker-group">
                    <span class="tracker-label">Game Turn</span>
                    <div class="turn-controls">
                        <button class="turn-btn" onclick="adjustTurn(-1)">-</button>
                        <span class="turn-value" id="turn-display-val">1</span>
                        <button class="turn-btn" onclick="adjustTurn(1)">+</button>
                    </div>
                </div>
                <div class="tracker-group">
                    <span class="tracker-label">Gear Phase</span>
                    <div class="phase-selector">
                        <button class="phase-btn active" id="phase-btn-1" onclick="setPhase(1)">1</button>
                        <button class="phase-btn" id="phase-btn-2" onclick="setPhase(2)">2</button>
                        <button class="phase-btn" id="phase-btn-3" onclick="setPhase(3)">3</button>
                        <button class="phase-btn" id="phase-btn-4" onclick="setPhase(4)">4</button>
                        <button class="phase-btn" id="phase-btn-5" onclick="setPhase(5)">5</button>
                        <button class="phase-btn" id="phase-btn-6" onclick="setPhase(6)">6</button>
                    </div>
                </div>
                <div class="phase-info" id="phase-info-text">
                    Gear Phase 1: Activating vehicles in Gear 1 or higher.
                </div>
            </div>

            <!-- Global In-Game Audience Votes HUB -->
            <div class="votes-hub">
                <div class="votes-hud-left">
                    <div class="votes-counter-big">
                        <span class="val" id="votes-display-val">0</span>
                        <span style="font-size: 0.65rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px;">Audience Votes</span>
                    </div>
                    <div class="votes-actions-grid">
                        <button class="vote-action-btn" onclick="adjustVotes(1)">
                            <span>Gain Vote</span>
                            <span class="cost">+1 Vote</span>
                        </button>
                        <button class="vote-action-btn" id="applause-vote-btn" onclick="spendVote('applause')">
                            <span>Thunderous Applause</span>
                            <span class="cost">Spend 1 Vote</span>
                        </button>
                        <button class="vote-action-btn" id="rubber-vote-btn" onclick="spendVote('rubber')">
                            <span>Burn Rubber</span>
                            <span class="cost">Spend 1 Vote</span>
                        </button>
                        <button class="vote-action-btn" id="reload-vote-btn" onclick="spendVote('reload')">
                            <span>Reload Weapon</span>
                            <span class="cost">Spend 2 Votes</span>
                        </button>
                        <button class="vote-action-btn" id="executive-vote-btn" onclick="spendVote('executive')">
                            <span>Intervention</span>
                            <span class="cost">Spend 2 Votes</span>
                        </button>
                        <button class="vote-action-btn" id="respawn-vote-btn" onclick="spendVote('respawn')">
                            <span>Respawn Wreck</span>
                            <span class="cost">Spend 3 / 1 Vote</span>
                        </button>
                    </div>
                </div>
                <div>
                    <button class="btn btn-danger" onclick="confirmResetGame()">Reset Game Stats</button>
                </div>
            </div>

            <div class="vehicles-grid" id="play-vehicles-container">
                <!-- In-game vehicle dashboards load here -->
            </div>
        </div>

        <!-- AI PROMPT TAB VIEW -->
        <div id="prompt-view" class="view-section">
            <div style="background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 12px; padding: 2rem; max-width: 600px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.5rem; backdrop-filter: blur(16px);">
                <h3 style="font-family: 'Orbitron', sans-serif; text-transform: uppercase; color: var(--glow-color); letter-spacing: 1px; border-bottom: 1px solid var(--card-border); padding-bottom: 0.8rem;">
                    🤖 AI Image Prompt Generator
                </h3>
                
                <div class="input-group">
                    <label for="prompt-vehicle-select">Select Vehicle</label>
                    <select id="prompt-vehicle-select" onchange="updatePromptTabOutput()">
                        <!-- Loaded dynamically with roster vehicles -->
                    </select>
                </div>

                <div class="input-group">
                    <label>Prompt Purpose</label>
                    <div style="display: flex; gap: 1.5rem; margin-top: 0.3rem;">
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem;">
                            <input type="radio" name="prompt-purpose" value="3d-model" checked onchange="updatePromptTabOutput()" style="accent-color: var(--glow-color); width: 16px; height: 16px;">
                            🧱 3D Model (Clay Render)
                        </label>
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.85rem;">
                            <input type="radio" name="prompt-purpose" value="in-game" onchange="updatePromptTabOutput()" style="accent-color: var(--glow-color); width: 16px; height: 16px;">
                            🎨 In-Game Card (Full Color, Transparent BG)
                        </label>
                    </div>
                </div>

                <div class="input-group">
                    <label>Generated Prompt</label>
                    <div style="background: rgba(0,0,0,0.3); padding: 1rem; border-radius: 8px; border: 1px solid var(--card-border); font-family: monospace; font-size: 0.85rem; color: var(--text-primary); word-break: break-word; min-height: 140px; max-height: 220px; overflow-y: auto;" id="prompt-tab-output-text">
                        <!-- Prompt text goes here -->
                    </div>
                </div>

                <button class="btn" onclick="copyPromptTabText()">📋 Copy Prompt & Switch to Garage</button>
            </div>
        </div>
    </main>

    <!-- Modal for adding items -->
    <div class="modal-overlay" id="selection-modal" onclick="closeModal(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <div class="modal-header">
                <h3 id="modal-title">Select Item</h3>
                <button class="close-modal-btn" onclick="closeModal()">&times;</button>
            </div>
            <input type="text" class="modal-search" id="modal-search-input" placeholder="Search items..." oninput="filterModalItems()">
            <div class="selection-list" id="modal-selection-list">
                <!-- Selectable options load dynamically -->
            </div>
        </div>
    </div>

    <!-- Gaslands Rules Database -->
    <script>
        // Database arrays
        const VEHICLE_TYPES = [
            { name: "Buggy", weight: "Lightweight", hull: 6, handling: 4, maxGear: 6, crew: 2, slots: 2, cost: 6, special: "Roll Cage: When this vehicle suffers a flip, this vehicle may choose to ignore the 2 hits received from the flip." },
            { name: "Car", weight: "Middleweight", hull: 10, handling: 3, maxGear: 5, crew: 2, slots: 2, cost: 12, special: "" },
