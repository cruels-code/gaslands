            vehicles: []
        };

        // UI active modal tracking
        let activeModalTargetVehicleId = null;
        let activeModalItemType = null; // "weapon", "upgrade", "perk"

        // Initialize application
        window.addEventListener("DOMContentLoaded", () => {
            loadSponsorsList();
            loadState();
            applySponsorTheme();
            renderHeader();
            renderSponsorInfo();
            renderVehicles();
        });

        // Save State
        function saveState() {
            localStorage.setItem("gaslands_manager_state", JSON.stringify(appState));
            calculateCansSpent();
        }

        // Load State
        function loadState() {
            const raw = localStorage.getItem("gaslands_manager_state");
            if (raw) {
                try {
                    const parsed = JSON.parse(raw);
                    appState = { ...appState, ...parsed };
                } catch (e) {
                    console.error("Failed to parse state", e);
                }
            }
            if (appState.turn === undefined) appState.turn = 1;
            if (appState.phase === undefined) appState.phase = 1;
            if (appState.vehicles.length === 0) {
                addVehicle(false);
            }
        }

        function applySponsorTheme() {
            const sp = appState.sponsor;
            const theme = SPONSOR_THEMES[sp] || SPONSOR_THEMES["Sponsorless"];
            
            document.documentElement.style.setProperty('--glow-color', theme.color);
            document.documentElement.style.setProperty('--glow-shadow', theme.glow);
        }

        function renderHeader() {
            document.getElementById("sponsor-select").value = appState.sponsor;
            document.getElementById("budget-input").value = appState.budget;
            document.getElementById("votes-display-val").textContent = appState.votes;
            
            // Adjust visual header theme logo color
            document.getElementById("header-logo").querySelector("span").style.color = "var(--glow-color)";
            
            // Turn & Phase displays
            const turnVal = document.getElementById("turn-display-val");
            if (turnVal) turnVal.textContent = appState.turn;
            
            for (let i = 1; i <= 6; i++) {
                const btn = document.getElementById(`phase-btn-${i}`);
                if (btn) {
                    btn.classList.toggle("active", appState.phase === i);
                }
            }
            const infoText = document.getElementById("phase-info-text");
            if (infoText) {
                infoText.textContent = `Gear Phase ${appState.phase}: Activating vehicles in Gear ${appState.phase} or higher.`;
            }

            calculateCansSpent();
        }

        function loadSponsorsList() {
            const select = document.getElementById("sponsor-select");
            select.innerHTML = "";
            Object.keys(SPONSOR_THEMES).forEach(spName => {
                const opt = document.createElement("option");
                opt.value = spName;
                opt.textContent = spName;
                select.appendChild(opt);
            });
        }

        function changeSponsor() {
            const select = document.getElementById("sponsor-select");
            appState.sponsor = select.value;
            
            validateSponsorConstraints();
            applySponsorTheme();
            renderHeader();
            renderSponsorInfo();
            renderVehicles();
            saveState();
        }

        function changeBudget() {
            const budgetInput = document.getElementById("budget-input");
            appState.budget = parseInt(budgetInput.value) || 50;
            renderHeader();
            saveState();
        }

        function renderSponsorInfo() {
            const panel = document.getElementById("sponsor-info-panel");
            const sp = SPONSORS.find(s => s.name === appState.sponsor);
            if (sp && sp.name !== "Sponsorless") {
                panel.style.display = "block";
                panel.innerHTML = `
                    <h4>${sp.name} Sponsored Rules</h4>
                    <p><strong>Perk Classes:</strong> ${sp.perks.map(p => p.charAt(0).toUpperCase() + p.slice(1)).join(', ')}</p>
                    <p style="margin-top: 0.2rem; font-size: 0.8rem; opacity: 0.8;">${sp.sponsored.join(' | ')}</p>
                `;
            } else {
                panel.style.display = "none";
            }
        }

        function switchMode(mode) {
            appState.mode = mode;
            document.getElementById("garage-mode-btn").classList.toggle("active", mode === "garage");
            document.getElementById("play-mode-btn").classList.toggle("active", mode === "play");
            document.getElementById("prompt-mode-btn").classList.toggle("active", mode === "prompt");
            
            document.getElementById("garage-view").classList.toggle("active", mode === "garage");
            document.getElementById("play-view").classList.toggle("active", mode === "play");
            document.getElementById("prompt-view").classList.toggle("active", mode === "prompt");
            
            document.getElementById("budget-input-group").style.display = mode === "play" ? "none" : "flex";
            document.getElementById("sponsor-input-group").style.display = mode === "play" ? "none" : "flex";

            if (mode === "prompt") {
                populatePromptVehicleDropdown();
                updatePromptTabOutput();
            }

            renderVehicles();
            saveState();
        }

        // Add Vehicle
        function addVehicle(shouldRender = true) {
            const randomName = RANDOM_NAMES[Math.floor(Math.random() * RANDOM_NAMES.length)];
            const newVehicle = {
                id: Date.now() + Math.random().toString(36).substr(2, 9),
                name: randomName,
                type: "Car",
                weapons: [], 
                upgrades: [], 
                perks: [], 
                imageUrl: null,
                
                // Play Stats
                damage: 0, 
                hazard: 0,
                gear: 1,
                onFire: false,
                ghostRider: false,
                distracted: false,
                wrecked: false,
                
                isPrisonCar: false
            };

            appState.vehicles.push(newVehicle);
            
            if (shouldRender) {
                renderVehicles();
                saveState();
            }
        }

        function removeVehicle(id) {
            appState.vehicles = appState.vehicles.filter(v => v.id !== id);
            renderVehicles();
            saveState();
        }

        // Validate sponsor rules and constraints
        function validateSponsorConstraints() {
            appState.vehicles.forEach(v => {
                const baseInfo = VEHICLE_TYPES.find(t => t.name === v.type);
                if (!baseInfo) return;

                if (appState.sponsor === "Rutherford" && baseInfo.weight === "Lightweight" && baseInfo.name !== "Tank" && baseInfo.name !== "Helicopter") {
                    v.type = "Car"; 
                }

                if (appState.sponsor === "Miyazaki" && baseInfo.handling <= 2) {
                    v.type = "Car"; 
                }

                if (appState.sponsor === "Idris" && v.type === "Gyrocopter") {
                    v.type = "Car";
                }

                if (appState.sponsor !== "Mishkin") {
                    v.weapons = v.weapons.filter(w => !w.electrical);
                    v.upgrades = v.upgrades.filter(u => {
                        const original = UPGRADES.find(orig => orig.name === u.name);
                        return !original || !original.electrical;
                    });
                }

                if (appState.sponsor !== "The Warden") {
                    v.isPrisonCar = false;
                }

                const allowedPerks = SPONSORS.find(s => s.name === appState.sponsor)?.perks || [];
                v.perks = v.perks.filter(p => allowedPerks.includes(p.class));
            });
        }

        // Calculate Cost and Slots used for a vehicle
        function calculateVehicleCans(vehicle) {
            const baseType = VEHICLE_TYPES.find(t => t.name === vehicle.type);
            if (!baseType) return 0;

            let cans = baseType.cost;

            if (vehicle.isPrisonCar && vehicle.type === "Car") {
                cans = Math.max(5, cans - 4); 
            }

            vehicle.weapons.forEach(w => {
                let cost = w.cost;
                if (w.facing === "Turret") {
                    cost = w.cost * 3; 
                }
                cans += cost;
            });

            vehicle.upgrades.forEach(u => {
                let cost = u.cost;
                if (appState.sponsor === "Idris" && u.name === "Nitro Booster") {
                    cost = 3;
                }
                if (appState.sponsor === "Scarlett" && u.name === "Extra Crewmember") {
                    cost = 2; 
                }
                cans += cost;
            });

            vehicle.perks.forEach(p => {
                cans += p.cost;
            });

            return cans;
        }

        function calculateVehicleSlots(vehicle) {
            let slots = 0;
            vehicle.weapons.forEach(w => {
                if ((vehicle.type === "Gyrocopter" || vehicle.type === "Helicopter") && w.category === "Dropped") {
                    // 0 slots
                } else {
                    slots += w.slots;
                }
            });
            vehicle.upgrades.forEach(u => {
                if (appState.sponsor === "Slime" && u.name === "Ram") {
                    // 0 slots
                } else {
                    slots += u.slots;
                }
            });
            return slots;
        }

        function calculateCansSpent() {
            let total = 0;
            appState.vehicles.forEach(v => {
                total += calculateVehicleCans(v);
            });
            
            const display = document.getElementById("cans-spent-display");
            display.textContent = `${total} / ${appState.budget}`;
            
            if (total > appState.budget) {
                display.classList.add("over-budget");
            } else {
                display.classList.remove("over-budget");
            }
        }

        // Render Vehicles lists
        function renderVehicles() {
            const garageContainer = document.getElementById("garage-vehicles-container");
            const playContainer = document.getElementById("play-vehicles-container");
            
            if (!garageContainer || !playContainer) return;
            
            garageContainer.innerHTML = "";
            playContainer.innerHTML = "";

            if (appState.vehicles.length === 0) {
                const empty = `
                    <div class="empty-team-state">
                        <p style="font-size: 1.2rem; font-weight: bold; font-family: 'Orbitron', sans-serif;">Empty Garage</p>
                        <p>You don't have any vehicles on this team yet. Add one to get started!</p>
                        <button class="btn" onclick="addVehicle()">➕ Add Vehicle</button>
                    </div>
                `;
                garageContainer.innerHTML = empty;
                playContainer.innerHTML = empty;
                return;
            }

            appState.vehicles.forEach(vehicle => {
                const baseInfo = VEHICLE_TYPES.find(t => t.name === vehicle.type) || VEHICLE_TYPES[0];
                const cans = calculateVehicleCans(vehicle);
                const slotsUsed = calculateVehicleSlots(vehicle);
                const slotsMax = baseInfo.slots;
                
                // Max Hull calculations
                let currentMaxHull = baseInfo.hull;
                if (vehicle.isPrisonCar && vehicle.type === "Car") {
                    currentMaxHull = baseInfo.hull - 2;
                }
                
                let armourCount = vehicle.upgrades.filter(u => u.name === "Armour Plating").length;
                currentMaxHull += (armourCount * 2);
                
                let microPlates = vehicle.upgrades.filter(u => u.name === "MicroPlate Armour").length;
                currentMaxHull += (microPlates * 2);

                // Max Gear calculations
                let hasTankTracks = vehicle.upgrades.some(u => u.name === "Tank Tracks");
                let currentMaxGear = hasTankTracks ? Math.max(1, baseInfo.maxGear - 1) : baseInfo.maxGear;
                
                let hasNuke = vehicle.upgrades.some(u => u.name === "Experimental Nuclear Engine");
                if (hasNuke) {
                    currentMaxGear = Math.min(6, currentMaxGear + 2);
                }

                // Warnings check
                const isSlotsViolated = slotsUsed > slotsMax;
                let warnings = [];
                if (isSlotsViolated) {
                    warnings.push(`Exceeded Build Slots: Using ${slotsUsed}/${slotsMax} Slots.`);
                }
                if (appState.sponsor === "Rutherford" && baseInfo.weight === "Lightweight" && vehicle.type !== "Tank" && vehicle.type !== "Helicopter") {
                    warnings.push(`Might Is Right: Rutherford cannot buy Lightweight vehicles.`);
                }
                if (appState.sponsor === "Miyazaki" && baseInfo.handling <= 2) {
                    warnings.push(`Elegance: Miyazaki cannot buy Handling <= 2 vehicles.`);
                }
                if (appState.sponsor === "Idris" && vehicle.type === "Gyrocopter") {
                    warnings.push(`Kiss My Asphalt: Idris cannot buy Gyrocopters.`);
                }
                
                if (appState.sponsor !== "Mishkin") {
                    const hasElectricalW = vehicle.weapons.some(w => w.electrical);
                    const hasElectricalU = vehicle.upgrades.some(u => {
                        const original = UPGRADES.find(orig => orig.name === u.name);
                        return original && original.electrical;
                    });
                    if (hasElectricalW || hasElectricalU) {
                        warnings.push(`Thumpermonkey: Electrical items are Mishkin exclusive.`);
                    }
                }

                if (appState.mode === "garage") {
                    // Render Garage Customize Card
                    let weaponsHtml = "";
                    if (vehicle.weapons.length === 0) {
                        weaponsHtml = `<div class="equipped-item" style="color: var(--text-dark); justify-content: center; font-style: italic;">No weapons equipped</div>`;
                    } else {
                        vehicle.weapons.forEach((w, index) => {
                            const weaponCostDisplay = w.facing === "Turret" ? w.cost * 3 : w.cost;
                            const slotDisplay = w.slots > 0 ? `${w.slots} Slot${w.slots > 1 ? 's' : ''}` : '0 Slots';
                            
                            // Check if zero slots weapon (no orientation needed)
                            const isZeroSlots = w.slots === 0;
                            const facingSelectorHtml = isZeroSlots ? 
                                `<span style="font-size: 0.75rem; color: var(--text-muted); font-weight: normal; margin-right: 0.5rem;">[360° Arc]</span>` :
                                `<select style="padding: 0.2rem; font-size: 0.75rem; width: 85px;" onchange="changeWeaponFacing('${vehicle.id}', ${index}, this.value)">
                                    <option value="Front" ${w.facing === 'Front' ? 'selected' : ''}>Front</option>
                                    <option value="Rear" ${w.facing === 'Rear' ? 'selected' : ''}>Rear</option>
                                    <option value="Left" ${w.facing === 'Left' ? 'selected' : ''}>Left</option>
                                    <option value="Right" ${w.facing === 'Right' ? 'selected' : ''}>Right</option>
                                    <option value="Side" ${w.facing === 'Side' ? 'selected' : ''}>Side</option>
                                    <option value="Turret" ${w.facing === 'Turret' ? 'selected' : ''}>Turret (x3)</option>
                                </select>`;

                            weaponsHtml += `
                                <div class="equipped-item">
                                    <div class="equipped-item-details">
                                        <div class="equipped-item-name">${w.name} ${isZeroSlots ? '' : `<span style="font-size:0.75rem; color: var(--glow-color); font-weight:normal;">(${w.facing})</span>`}</div>
                                        <div class="equipped-item-desc">${w.range} • ${w.dice} • ${slotDisplay}</div>
                                    </div>
                                    <div class="item-controls">
                                        ${facingSelectorHtml}
                                        <span class="selection-item-cost" style="font-size: 0.8rem;">${weaponCostDisplay} C</span>
                                        <button class="remove-item-btn" onclick="removeItem('${vehicle.id}', 'weapon', ${index})">&times;</button>
                                    </div>
                                </div>
                            `;
                        });
                    }

                    let upgradesHtml = "";
                    if (vehicle.upgrades.length === 0) {
                        upgradesHtml = `<div class="equipped-item" style="color: var(--text-dark); justify-content: center; font-style: italic;">No upgrades equipped</div>`;
                    } else {
                        vehicle.upgrades.forEach((u, index) => {
                            let cost = u.cost;
                            if (appState.sponsor === "Idris" && u.name === "Nitro Booster") cost = 3;
                            if (appState.sponsor === "Scarlett" && u.name === "Extra Crewmember") cost = 2;
                            
                            // Check if upgrade is a Ram / Exploding Ram (designation needed)
                            const needsFacing = u.name === "Ram" || u.name === "Exploding Ram";
                            const facingSelectorHtml = needsFacing ? 
                                `<select style="padding: 0.1rem; font-size: 0.75rem; width: 75px; margin-right: 0.5rem;" onchange="changeUpgradeFacing('${vehicle.id}', ${index}, this.value)">
                                    <option value="Front" ${u.facing === 'Front' ? 'selected' : ''}>Front</option>
                                    <option value="Rear" ${u.facing === 'Rear' ? 'selected' : ''}>Rear</option>
                                </select>` : '';
                            
                            const facingDisplay = u.facing ? ` (${u.facing})` : '';

                            upgradesHtml += `
                                <div class="equipped-item">
                                    <div class="equipped-item-details">
                                        <div class="equipped-item-name">${u.name}${facingDisplay}</div>
                                        <div class="equipped-item-desc">${u.slots > 0 ? `${u.slots} Slots` : '0 Slots'}</div>
                                    </div>
                                    <div class="item-controls">
                                        ${facingSelectorHtml}
                                        <span class="selection-item-cost" style="font-size: 0.8rem;">${cost} C</span>
                                        <button class="remove-item-btn" onclick="removeItem('${vehicle.id}', 'upgrade', ${index})">&times;</button>
                                    </div>
                                </div>
                            `;
                        });
                    }

                    let perksHtml = "";
                    if (vehicle.perks.length === 0) {
                        perksHtml = `<div class="equipped-item" style="color: var(--text-dark); justify-content: center; font-style: italic;">No perks selected</div>`;
                    } else {
                        vehicle.perks.forEach((p, index) => {
                            perksHtml += `
                                <div class="equipped-item">
                                    <div class="equipped-item-details">
                                        <div class="equipped-item-name">${p.name}</div>
                                        <div class="equipped-item-desc">${p.class.toUpperCase()}</div>
                                    </div>
                                    <div class="item-controls">
                                        <span class="selection-item-cost" style="font-size: 0.8rem;">${p.cost} C</span>
                                        <button class="remove-item-btn" onclick="removeItem('${vehicle.id}', 'perk', ${index})">&times;</button>
                                    </div>
                                </div>
                            `;
                        });
                    }

                    let wardenControlHtml = "";
                    if (appState.sponsor === "The Warden" && vehicle.type === "Car") {
                        wardenControlHtml = `
                            <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; cursor: pointer;">
                                <input type="checkbox" ${vehicle.isPrisonCar ? 'checked' : ''} onchange="togglePrisonCar('${vehicle.id}')" style="accent-color: var(--glow-color);">
                                💥 Prison Car Conversion (-4 Cans, -2 Hull Value)
                            </label>
                        `;
                    }

                    // Render card image slot in garage
                    let imageSlotHtml = "";
                    if (vehicle.imageUrl) {
                        imageSlotHtml = `
                            <div style="position: relative; width: 100%; height: 160px; border-radius: 8px; overflow: hidden; border: 1px solid var(--card-border);">
                                <img src="${vehicle.imageUrl}" style="width: 100%; height: 100%; object-fit: contain;">
                                <button class="btn" style="position: absolute; bottom: 8px; right: 8px; padding: 0.25rem 0.5rem; font-size: 0.65rem; background: rgba(15, 23, 42, 0.85);" onclick="triggerImageUpload('${vehicle.id}')">🔄 Swap Image</button>
                                <button class="btn btn-danger" style="position: absolute; bottom: 8px; left: 8px; padding: 0.25rem 0.5rem; font-size: 0.65rem; background: rgba(15, 23, 42, 0.85);" onclick="clearVehicleImage('${vehicle.id}')">Remove</button>
                            </div>
                        `;
                    } else {
                        imageSlotHtml = `
                            <div style="width: 100%; height: 120px; border: 1px dashed var(--card-border); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.4rem; background: rgba(0,0,0,0.15);">
                                <span style="font-size: 0.75rem; color: var(--text-muted); text-transform: uppercase; font-family:'Orbitron', sans-serif;">No Chassis Image</span>
                                <div style="display: flex; gap: 0.35rem;">
                                    <button class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.65rem;" onclick="goToPromptTab('${vehicle.id}')">🤖 AI Prompt</button>
                                    <button class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.65rem;" onclick="triggerImageUpload('${vehicle.id}')">📁 Upload</button>
                                </div>
                            </div>
                        `;
                    }

                    const card = document.createElement("div");
                    card.className = "vehicle-card";
                    card.innerHTML = `
                        <div class="card-header">
                            <div class="vehicle-name-block">
                                <input type="text" class="vehicle-title-input" value="${vehicle.name}" onchange="updateVehicleName('${vehicle.id}', this.value)" placeholder="Car Name">
                                <select onchange="updateVehicleType('${vehicle.id}', this.value)" style="margin-top:0.2rem; font-size: 0.8rem; padding: 0.2rem;">
                                    ${VEHICLE_TYPES.map(t => `<option value="${t.name}" ${t.name === vehicle.type ? 'selected' : ''}>${t.name.toUpperCase()} (${t.cost} Cans)</option>`).join('')}
                                </select>
                            </div>
                            <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.2rem;">
                                <span class="selection-item-cost" style="font-size: 1.1rem;">${cans} Cans</span>
                                <span style="font-size: 0.75rem; color: var(--text-muted);">${slotsUsed} / ${slotsMax} Slots</span>
                                <button class="remove-item-btn" style="font-size: 0.75rem; margin-top: 0.35rem;" onclick="removeVehicle('${vehicle.id}')">Delete Vehicle</button>
                            </div>
                        </div>

                        ${imageSlotHtml}
                        <input type="file" id="image-upload-input-${vehicle.id}" style="display: none;" onchange="handleImageUpload(event, '${vehicle.id}')" accept="image/*">
                        
                        <div class="stats-badge-grid">
                            <div class="stat-badge">
                                <span class="label">Hull</span>
                                <span class="val">${currentMaxHull}</span>
                            </div>
                            <div class="stat-badge">
                                <span class="label">Handling</span>
                                <span class="val">${hasTankTracks ? baseInfo.handling + 1 : baseInfo.handling}</span>
                            </div>
                            <div class="stat-badge">
                                <span class="label">Max Gear</span>
                                <span class="val">${currentMaxGear}</span>
                            </div>
                            <div class="stat-badge">
                                <span class="label">Crew</span>
                                <span class="val">${baseInfo.crew + vehicle.upgrades.filter(u => u.name === "Extra Crewmember").length}</span>
                            </div>
                        </div>

                        ${wardenControlHtml}

                        <div class="garage-section">
                            <div class="section-title">
                                <span>Weapons</span>
                                <button class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;" onclick="openSelectionModal('${vehicle.id}', 'weapon')">+ Add</button>
                            </div>
                            <div class="item-list">${weaponsHtml}</div>
                        </div>

                        <div class="garage-section">
                            <div class="section-title">
                                <span>Upgrades</span>
                                <button class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;" onclick="openSelectionModal('${vehicle.id}', 'upgrade')">+ Add</button>
                            </div>
                            <div class="item-list">${upgradesHtml}</div>
                        </div>

                        <div class="garage-section">
                            <div class="section-title">
                                <span>Perks</span>
                                <button class="btn" style="padding: 0.2rem 0.5rem; font-size: 0.7rem;" onclick="openSelectionModal('${vehicle.id}', 'perk')">+ Add</button>
                            </div>
                            <div class="item-list">${perksHtml}</div>
                        </div>

                        ${warnings.length > 0 ? `
                            <div class="warning-msg">
                                ${warnings.map(w => `<div class="warning-msg-item">${w}</div>`).join('')}
                            </div>
                        ` : ''}
                    `;
                    garageContainer.appendChild(card);
                    
                } else {
                    // Render Play Mode Card
                    let hullBoxesHtml = "";
                    for (let i = 1; i <= currentMaxHull; i++) {
                        let classState = "filled";
                        // Left-to-right sequential damage: if index is <= damage, it is marked as damaged
                        if (i <= vehicle.damage) {
                            classState = "damaged";
                        }
                        hullBoxesHtml += `<div class="hull-point-box ${classState}" onclick="toggleHullDamage('${vehicle.id}', ${i})"></div>`;
                    }

                    let hazardLimit = 6;
                    if (appState.sponsor === "Rusty's Bootleggers") {
                        hazardLimit = 8;
                    }
                    let hazardDotsHtml = "";
                    for (let i = 1; i <= hazardLimit; i++) {
                        let classState = "";
                        if (i <= vehicle.hazard) {
                            classState = "active";
                            if (vehicle.hazard >= hazardLimit) {
                                classState = "active warning";
                            }
                        }
                        hazardDotsHtml += `<div class="hazard-dot ${classState}" onclick="setHazard('${vehicle.id}', ${i})"></div>`;
                    }

                    let gearButtonsHtml = "";
                    for (let i = 1; i <= 6; i++) {
                        let disabled = i > currentMaxGear ? "disabled" : "";
                        let active = i === vehicle.gear ? "class='gear-btn active'" : "class='gear-btn'";
                        gearButtonsHtml += `<button ${active} ${disabled} onclick="setGear('${vehicle.id}', ${i})">${i}</button>`;
                    }

                    let playWeaponsHtml = "";
                    vehicle.weapons.forEach((w, index) => {
