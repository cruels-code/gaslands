        function handleImageUpload(event, vehicleId) {
            const file = event.target.files[0];
            if (!file) return;
            
            const reader = new FileReader();
            reader.onload = function(e) {
                // Apply transparency mask removing white background pixels
                removeWhiteBackground(e.target.result, function(maskedDataUrl) {
                    const v = appState.vehicles.find(car => car.id === vehicleId);
                    if (v) {
                        v.imageUrl = maskedDataUrl;
                        renderVehicles();
                        saveState();
                    }
                });
            };
            reader.readAsDataURL(file);
        }

        function removeWhiteBackground(dataUrl, callback) {
            const img = new Image();
            img.onload = function() {
                const canvas = document.createElement("canvas");
                canvas.width = img.width;
                canvas.height = img.height;
                const ctx = canvas.getContext("2d");
                ctx.drawImage(img, 0, 0);
                
                const imgData = ctx.getImageData(0, 0, canvas.width, canvas.height);
                const data = imgData.data;
                
                // Color key threshold: key out neutral white/light-grey down to 210 RGB
                for (let i = 0; i < data.length; i += 4) {
                    const r = data[i];
                    const g = data[i+1];
                    const b = data[i+2];
                    
                    // Check if pixel is neutral (close to grayscale) and very bright
                    if (r > 210 && g > 210 && b > 210 && 
                        Math.abs(r - g) < 15 && 
                        Math.abs(r - b) < 15 && 
                        Math.abs(g - b) < 15) {
                        data[i+3] = 0; // Set Alpha to fully transparent
                    }
                }
                
                ctx.putImageData(imgData, 0, 0);
                callback(canvas.toDataURL("image/png"));
            };
            img.src = dataUrl;
        }

